{
  "productName": "Pixel Agents",
  "version": "0.1.0",
  "identifier": "com.pixel-agents.app",
  "build": {
    "beforeDevCommand": "cd webview-ui && npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd webview-ui && npm run build",
    "frontendDist": "../webview-ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Pixel Agents",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
